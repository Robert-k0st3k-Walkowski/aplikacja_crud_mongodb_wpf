<Window x:Class="SamochodyProject.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SamochodyProject"
        xmlns:vm="clr-namespace:SamochodyProject.ViewModel"
        xmlns:etlk="http://schemas.xceed.com/wpf/xaml/toolkit"
        mc:Ignorable="d"
        Title="SamochodyBazyDanych" Height="535" Width="900" MinHeight="535" MinWidth="900" WindowState="Maximized" Icon="/Ikona_auto.ico">
    <Window.Resources>
        <vm:CreateDocument x:Key="CreateVM"/>
        <vm:ReadDocument x:Key="ReadVM"/>
        <vm:DeleteDocument x:Key="DeleteVM"/>
        <vm:UpdateDocument x:Key="UpdateVM"/>
    </Window.Resources>

    <Window.Background>
        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="Red" Offset="0.1"/>
            <GradientStop Color="Orange" Offset="0.5" />
            <GradientStop Color="Yellow" Offset="0.7" />
        </LinearGradientBrush>
    </Window.Background>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <StackPanel Name="FirstStackPanel" Grid.Column="0" Margin="5" VerticalAlignment="Stretch" HorizontalAlignment="Stretch">
            <Label Content="EDYCJA DOKUMENTU:" FontFamily="Corbel" FontWeight="Bold" FontSize="20" Margin="130,0,150,0"/>
            <DockPanel Name="FirstDockPanel" Width="370" Height="90"
                       Margin="5" HorizontalAlignment="Left" VerticalAlignment="Top" DataContext="{x:Static vm:SharedCarProperties.Instance}">

                <GroupBox Name="CollectionGroupBox" Width="120" Height="70" Margin="5"
                          DockPanel.Dock="Left" VerticalAlignment="Top" HorizontalAlignment="Left"
                          Header="Kolekcja:" FontFamily="Corbel" FontWeight="Bold">
                    <StackPanel>
                        <RadioButton Name="EuropejskieRadioButton" Content="Europejskie" IsChecked="{Binding European, Mode=TwoWay}"/>
                        <RadioButton Name="AmerykanskieRadioButton" Content="Amerykańskie" IsChecked="{Binding American, Mode=TwoWay}"/>
                        <RadioButton Name="AzjatyckieRadioButton" Content="Azjatyckie" IsChecked="{Binding Asian, Mode=TwoWay}"/>
                    </StackPanel>
                </GroupBox>

                <StackPanel Name="SecondStackPanel" Width="{Binding ElementName=MarkaTextBox, Path=Width}" Margin="5"
                            DockPanel.Dock="Left" HorizontalAlignment="Left" DataContext="{x:Static vm:SharedCarProperties.Instance}">
                    <Label Name="MarkaLabel" Content="Marka:" FontFamily="Corbel" FontWeight="Bold"/>
                    <TextBox Name="MarkaTextBox" Text="{Binding Brand, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}" Width="110"/>
                </StackPanel>

                <StackPanel Name="ThirdStackPanel" Width="{Binding ElementName=ModelTextBox, Path=Width}" Margin="5"
                            DockPanel.Dock="Left" HorizontalAlignment="Left" DataContext="{x:Static vm:SharedCarProperties.Instance}">
                    <Label Name="ModelLabel" Content="Model:" FontFamily="Corbel" FontWeight="Bold"/>
                    <TextBox Name="ModelTextBox" Text="{Binding Model, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}" Width="110" TextWrapping="Wrap"/>
                </StackPanel>

            </DockPanel>

            <DockPanel Name="SecondDockPanel" Margin="5" Width="{Binding ElementName=FirstDockPanel, Path=Width}"
                       HorizontalAlignment="Left" VerticalAlignment="Top" DataContext="{x:Static vm:SharedCarProperties.Instance}">

                <StackPanel Name="FourthStackPanel" Width="{Binding ElementName=RocznikTextBox, Path=Width}" Margin="5"
                            DockPanel.Dock="Left" HorizontalAlignment="Left">
                    <Label Name="RocznikLabel" Content="Rocznik:" FontFamily="Corbel" FontWeight="Bold"/>
                    <etlk:UIntegerUpDown Name="RocznikIntegerUpDown" Width="115"
                                    DefaultValue="2000" Value="{Binding Vintage, Mode=TwoWay}"/>
                </StackPanel>

                <StackPanel Name="FifthStackPanel" Width="{Binding ElementName=ModelTextBox, Path=Width}" Margin="5"
                            DockPanel.Dock="Left" HorizontalAlignment="Left" DataContext="{x:Static vm:SharedCarProperties.Instance}">
                    <Label Name="KolorLabel" Content="Kolor:" FontFamily="Corbel" FontWeight="Bold"/>
                    <TextBox Name="KolorTextBox" Text="{Binding CarColor, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}" Width="110"/>
                </StackPanel>

                <StackPanel Name="SixthStackPanel" Width="{Binding ElementName=ModelTextBox, Path=Width}" Margin="5"
                            DockPanel.Dock="Left" HorizontalAlignment="Left" DataContext="{x:Static vm:SharedCarProperties.Instance}">
                    <Label Name="RodzajNadwoziaLabel" Content="Rodzaj nadwozia:" FontFamily="Corbel" FontWeight="Bold"/>
                    <ComboBox Name="RodzajNadwoziaComboBox" SelectedValuePath="Content" SelectedValue="{Binding BodyKind, Mode=TwoWay}">
                        <ComboBoxItem Content="Kombi" IsSelected="True"/>
                        <ComboBoxItem Content="Sedan"/>
                        <ComboBoxItem Content="Hatchback"/>
                        <ComboBoxItem Content="SUV"/>
                        <ComboBoxItem Content="Coupe"/>
                        <ComboBoxItem Content="Van"/>
                        <ComboBoxItem Content="Minivan"/>
                        <ComboBoxItem Content="Kabriolet"/>
                    </ComboBox>
                </StackPanel>
            </DockPanel>

            <DockPanel Name="ThirdDockPanel" Margin="5" Width="400"
                       HorizontalAlignment="Left" VerticalAlignment="Top"
                       DataContext="{StaticResource CreateVM}">

                <Button Name="AddingButton" Width="100" Height="30" Margin="5,10,15,10"
                        DockPanel.Dock="Left" HorizontalAlignment="Left" Content="Dodaj dokument"
                        Command="{Binding GenerateDocumentCommand}" FontFamily="Corbel" FontWeight="Bold"/>
                <Button Name="UpdatingButton" Width="130" Height="30" Margin="15,10,15,10"
                        VerticalAlignment="Center" HorizontalAlignment="Center" Content="Uaktualnij dokument" DataContext="{StaticResource UpdateVM}"
                        Command="{Binding UpdateDocumentCommand}" FontFamily="Corbel" FontWeight="Bold"/>
                <Button Name="DeletingButton" Width="100" Height="30" Margin="15,10,5,10"
                        DockPanel.Dock="Right" HorizontalAlignment="Right"  Content="Usuń dokument" DataContext="{StaticResource DeleteVM}"
                        Command="{Binding DeleteSelectedDocumentCommand}" FontFamily="Corbel" FontWeight="Bold"/>
            </DockPanel>

            <DockPanel DataContext="{StaticResource CreateVM}">
                <Button Name="ResettingButton" Width="170" Height="30" Margin="5,5,15,5"
                        DockPanel.Dock="Left" HorizontalAlignment="Left" VerticalAlignment="Top" Content="Resetuj podane własności"
                        Command="{Binding ResetPropertiesCommand}" FontFamily="Corbel" FontWeight="Bold"/>
                <StackPanel>
                    <Button Name="SelectImageButton" Width="170" Height="30" Margin="15,5,5,5"
                            DockPanel.Dock="Right" HorizontalAlignment="Right" Content="Wybierz obraz samochodu"
                            Command="{Binding SelectImageCommand}" FontFamily="Corbel" FontWeight="Bold"/>
                    <TextBlock Name="SelectImageTextBlock" DockPanel.Dock="Bottom" Margin="0,0,5,5"
                               HorizontalAlignment="Right" VerticalAlignment="Bottom"
                               DataContext="{x:Static vm:SharedCarProperties.Instance}" Text="{Binding ImageUploadSuccess}"/>
                </StackPanel>
            </DockPanel>

            <StackPanel>
                <Border BorderThickness="2" BorderBrush="Black" CornerRadius="2" Width="410"/>
                <Label Content="WYŚWIETLANIE KOLEKCJI:" FontFamily="Cooper Black" FontSize="15" Margin="140,0,100,0"/>
            </StackPanel>

            <StackPanel Name="FourthDockPanel" Margin="5" Width="{Binding ElementName=ReadingCollectionButton, Path=Width}"
                        VerticalAlignment="Top" HorizontalAlignment="Center" DataContext="{x:Static vm:SharedCarProperties.Instance}">
                <DockPanel HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,0,0,5">
                    <StackPanel Margin="5">
                        <Label Content="Kolekcja (odczyt):" HorizontalAlignment="Center" FontFamily="Cooper Black"/>
                        <StackPanel Orientation="Horizontal">
                            <RadioButton Content="Europejskie" FontFamily="Cooper Black" IsChecked="{Binding European, Mode=TwoWay}" Margin="2"/>
                            <RadioButton Content="Amerykańskie" FontFamily="Cooper Black" IsChecked="{Binding American, Mode=TwoWay}" Margin="2"/>
                            <RadioButton Content="Azjatyckie" FontFamily="Cooper Black" IsChecked="{Binding Asian, Mode=TwoWay}" Margin="2"/>
                        </StackPanel>
                    </StackPanel>
                </DockPanel>
                <DockPanel DataContext="{StaticResource ReadVM}">

                    <Button Name="ReadingColButton" Content="Odczytaj kolekcje" Width="120" Height="30"
                            Margin="10,0" Command="{Binding LoadDocumentsCommand}" FontFamily="Cooper Black"/>

                    <Button Content="Wyczyść wybór" Width="110" Height="30" Margin="10,0"
                            Command="{Binding ClearSelectionCommand}" FontFamily="Cooper Black"/>

                    <Button Content="Pobierz dokument" Width="130" Height="30" Margin="10,0"
                            Command="{Binding SaveDocumentToFileCommand}" FontFamily="Cooper Black"/>
                </DockPanel>

            </StackPanel>
            
            <TextBlock DataContext="{StaticResource ReadVM}" Text="{Binding SaveElapsedText}"
                       Margin="10,10,10,10" Foreground="Black" FontWeight="Bold" HorizontalAlignment="Left" TextWrapping="Wrap"/>
            
        </StackPanel>

        <DockPanel Name="SeventhStackPanel" Grid.Column="1" Margin="5"
                   VerticalAlignment="Stretch" HorizontalAlignment="Center" LastChildFill="True"
                   DataContext="{StaticResource ReadVM}">

            <DockPanel DockPanel.Dock="Bottom" LastChildFill="True" Margin="5" Width="{Binding ElementName=DataGridDataReadingSpace, Path=Width}"
                       DataContext="{x:Static vm:SharedCarProperties.Instance}" Background="LightGray">
                <Border BorderBrush="Black" BorderThickness="1" Padding="4" Height="210">
                    <Image Source="{Binding ImageSource}" Stretch="Uniform" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                </Border>
            </DockPanel>

            <DataGrid Name="DataGridDataReadingSpace"
                      DataContext="{StaticResource ReadVM}"
                      ItemsSource="{Binding Documents}"
                      SelectedItem="{Binding SelectedDocument, Mode=TwoWay}"
                      AutoGenerateColumns="False"
                      EnableRowVirtualization="True" EnableColumnVirtualization="True"
                      DockPanel.Dock="Top" Margin="5" Background="LightGray">
                <DataGrid.Resources>
                    <Style x:Key="TextWrapStyle" TargetType="TextBlock">
                        <Setter Property="TextWrapping" Value="Wrap"/>
                        <Setter Property="TextAlignment" Value="Center"/>
                        <Setter Property="VerticalAlignment" Value="Top"/>
                        <Setter Property="Padding" Value="4,2,4,2"/>
                    </Style>
                </DataGrid.Resources>
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Id" Binding="{Binding [_id]}" Width="*" IsReadOnly="True" ElementStyle="{StaticResource TextWrapStyle}"/>
                    <DataGridTextColumn Header="Marka" Binding="{Binding [marka]}" Width="*" ElementStyle="{StaticResource TextWrapStyle}"/>
                    <DataGridTextColumn Header="Model" Binding="{Binding [model]}" Width="*" ElementStyle="{StaticResource TextWrapStyle}"/>
                    <DataGridTextColumn Header="Kolor" Binding="{Binding [kolor]}" Width="*" ElementStyle="{StaticResource TextWrapStyle}"/>
                    <DataGridTextColumn Header="Rocznik" Binding="{Binding [rocznik]}" Width="Auto" ElementStyle="{StaticResource TextWrapStyle}"/>
                    <DataGridTextColumn Header="Nadwozie" Binding="{Binding [rodzaj nadwozia]}" Width="*" ElementStyle="{StaticResource TextWrapStyle}"/>
                    <DataGridTextColumn Header="Plik" Binding="{Binding [imageFilename]}" Width="*" ElementStyle="{StaticResource TextWrapStyle}"/>
                </DataGrid.Columns>
            </DataGrid>

        </DockPanel>
    </Grid>
</Window>
